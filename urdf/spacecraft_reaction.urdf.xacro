<?xml version="1.0"?>
<robot name="spacecraft_reaction" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <link name="spacecraft_base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="400.0"/>
      <inertia ixx="81.333333" ixy="0.0" ixz="0.0" iyy="108.333333" iyz="0.0" izz="123.0"/>
    </inertial>
    <visual>
      <geometry><box size="1.5 1.2 1.0"/></geometry>
      <material name="spacecraft_white"><color rgba="0.75 0.75 0.8 1.0"/></material>
    </visual>
    <collision><geometry><box size="1.5 1.2 1.0"/></geometry></collision>
  </link>

  <link name="wrist_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.20" ixy="0.0" ixz="0.0" iyy="0.20" iyz="0.0" izz="0.389"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.18" length="0.15"/></geometry>
      <material name="wrist_blue"><color rgba="0.1 0.25 0.8 1.0"/></material>
    </visual>
    <!-- An off-axis marker makes rotation about the cylindrical joint visible. -->
    <visual>
      <origin xyz="0.19 0 0" rpy="0 0 0"/>
      <geometry><box size="0.16 0.06 0.10"/></geometry>
      <material name="wrist_marker_orange"><color rgba="1.0 0.28 0.02 1.0"/></material>
    </visual>
    <collision><geometry><cylinder radius="0.18" length="0.15"/></geometry></collision>
  </link>

  <!-- No joint connects spacecraft_base to world: the model is free floating. -->
  <joint name="joint_6" type="continuous">
    <parent link="spacecraft_base"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.65" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="50.0" velocity="4.0"/>
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint_6">
      <command_interface name="effort">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
      <odom_publish_frequency>100</odom_publish_frequency>
    </plugin>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find spacecraft_reaction_sim)/config/controllers.yaml</parameters>
      <hold_joints>false</hold_joints>
    </plugin>
  </gazebo>
</robot>
